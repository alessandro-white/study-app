<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:StudyApp.ViewModels"
             xmlns:views="clr-namespace:StudyApp.Views"
             x:Class="StudyApp.App">
  <Application.DataTemplates>
    <DataTemplate DataType="{x:Type vm:LoginViewModel}">
      <views:LoginView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:RegisterViewModel}">
      <views:RegisterView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
      <views:DashboardView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ModuleDetailViewModel}">
      <views:ModuleDetailView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:CreateEditModuleViewModel}">
      <views:CreateEditModuleView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:CreateEditNoteViewModel}">
      <views:CreateEditNoteView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ReviewViewModel}">
      <views:ReviewView/>
    </DataTemplate>
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme />
  </Application.Styles>
</Application>
