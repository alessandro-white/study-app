<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:StudyApp.ViewModels"
             xmlns:models="clr-namespace:StudyApp.Models"
             x:Class="StudyApp.Views.DashboardView"
             x:DataType="vm:DashboardViewModel"
             Background="#F5F5F7">
  <Grid RowDefinitions="Auto,*">
    <!-- Top Bar -->
    <Border Grid.Row="0" Background="White" Padding="24,16" BoxShadow="0 1 0 0 #15000000">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel>
          <TextBlock Text="StudyApp" FontSize="13" Foreground="#6E6E73"/>
          <TextBlock Text="{Binding WelcomeText}" FontSize="20" FontWeight="SemiBold" Foreground="#1D1D1F"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <Button Content="+ New Module"
                  Command="{Binding AddModuleCommand}"
                  Background="#007AFF"
                  Foreground="White"
                  CornerRadius="8"
                  Padding="16,8"
                  FontWeight="SemiBold"/>
          <Button Content="Sign Out"
                  Command="{Binding LogoutCommand}"
                  Background="Transparent"
                  Foreground="#6E6E73"
                  CornerRadius="8"
                  Padding="12,8"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Module Grid -->
    <ScrollViewer Grid.Row="1" Padding="24">
      <ItemsControl ItemsSource="{Binding Modules}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel Orientation="Horizontal"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type models:Module}">
            <Border Background="White"
                    CornerRadius="16"
                    Padding="0"
                    Margin="0,0,16,16"
                    Width="260"
                    BoxShadow="0 2 12 0 #0D000000"
                    ClipToBounds="True">
              <Grid RowDefinitions="8,*">
                <!-- Color stripe -->
                <Border Grid.Row="0" Background="{Binding Color}" CornerRadius="16,16,0,0"/>
                <!-- Card content -->
                <Border Grid.Row="1" Padding="20,16,20,16">
                <StackPanel Spacing="12">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="SemiBold" Foreground="#1D1D1F" TextWrapping="Wrap"/>
                    <Border Grid.Column="1"
                            Background="{Binding Color}"
                            CornerRadius="12"
                            Padding="8,4">
                      <TextBlock Text="{Binding DueCount}" FontSize="12" FontWeight="Bold" Foreground="White"/>
                    </Border>
                  </Grid>
                  <TextBlock Text="{Binding Description}"
                             FontSize="13"
                             Foreground="#6E6E73"
                             TextWrapping="Wrap"
                             MaxHeight="40"
                             IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                  <TextBlock FontSize="12" Foreground="#8E8E93">
                    <TextBlock.Text>
                      <MultiBinding StringFormat="{}{0} cards · {1} due">
                        <Binding Path="TotalCount"/>
                        <Binding Path="DueCount"/>
                      </MultiBinding>
                    </TextBlock.Text>
                  </TextBlock>
                  <!-- Action buttons -->
                  <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,4,0,0">
                    <Button Content="Study Now"
                            Command="{Binding $parent[ItemsControl].((vm:DashboardViewModel)DataContext).StudyModuleCommand}"
                            CommandParameter="{Binding}"
                            Background="#007AFF"
                            Foreground="White"
                            CornerRadius="8"
                            Padding="12,7"
                            FontSize="13"
                            FontWeight="SemiBold"/>
                    <Button Grid.Column="1"
                            Content="✎"
                            Command="{Binding $parent[ItemsControl].((vm:DashboardViewModel)DataContext).EditModuleCommand}"
                            CommandParameter="{Binding}"
                            Background="Transparent"
                            Foreground="#007AFF"
                            Padding="8,7"
                            FontSize="14"
                            Margin="6,0,0,0"/>
                    <Button Grid.Column="2"
                            Content="Open"
                            Command="{Binding $parent[ItemsControl].((vm:DashboardViewModel)DataContext).OpenModuleCommand}"
                            CommandParameter="{Binding}"
                            Background="Transparent"
                            Foreground="#007AFF"
                            Padding="8,7"
                            FontSize="13"
                            FontWeight="SemiBold"/>
                  </Grid>
                </StackPanel>
                </Border>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
